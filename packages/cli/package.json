{
  "name": "reeldocs",
  "version": "0.1.0",
  "description": "Generate documentation from product videos",
  "bin": {
    "reeldocs": "./dist/src/index.js"
  },
  "type": "module",
  "exports": {
    ".": "./dist/src/ai/pipeline.js",
    "./ai": "./dist/src/ai/gemini.js",
    "./prompts": "./dist/src/ai/prompts.js",
    "./analyze": "./dist/src/analyze/index.js",
    "./record": "./dist/src/record/index.js",
    "./produce": "./dist/src/produce/index.js",
    "./plan": "./dist/src/analyze/plan-schema.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "documentation",
    "video",
    "ai",
    "docs",
    "generator",
    "cli"
  ],
  "license": "AGPL-3.0",
  "dependencies": {
    "@google/genai": "^1.40.0",
    "commander": "^13.0.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.1",
    "ora": "^8.0.0",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
